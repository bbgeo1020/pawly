<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pawly_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/pawly_teal"
            android:padding="20dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏠 Espace Gardien"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/pawly_white"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PAWLY — Your pets are in good paws"
                    android:textSize="12sp"
                    android:textColor="#E0F7F7"/>

            </LinearLayout>

            <Button
                android:id="@+id/btnPrestataireProfile"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="👤"
                android:textSize="18sp"
                android:backgroundTint="@color/pawly_teal_dark"
                android:textColor="@color/pawly_white"/>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="75dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/pawly_white"
                    android:layout_marginRight="5dp">
                    <TextView
                        android:id="@+id/tvPrestataireNote"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⭐ 4.8"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/pawly_orange"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ma note"
                        android:textSize="11sp"
                        android:textColor="@color/pawly_grey"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="75dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/pawly_white"
                    android:layout_marginLeft="5dp"
                    android:layout_marginRight="5dp">
                    <TextView
                        android:id="@+id/tvPrestataireAvis"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 avis"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/pawly_teal"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Avis reçus"
                        android:textSize="11sp"
                        android:textColor="@color/pawly_grey"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="75dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/pawly_white"
                    android:layout_marginLeft="5dp">
                    <TextView
                        android:id="@+id/tvPrestataireGardes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 gardes"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/pawly_dark"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total gardes"
                        android:textSize="11sp"
                        android:textColor="@color/pawly_grey"/>
                </LinearLayout>

            </LinearLayout>

            <!-- Boutons navigation -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">

                <Button
                    android:id="@+id/btnVoirGardesAcceptees"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="✅ Mes gardes"
                    android:backgroundTint="@color/pawly_teal"
                    android:textColor="@color/pawly_white"
                    android:textSize="12sp"
                    android:layout_marginRight="5dp"/>

                <Button
                    android:id="@+id/btnVoirAvis"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="⭐ Mes avis"
                    android:backgroundTint="@color/pawly_orange"
                    android:textColor="@color/pawly_white"
                    android:textSize="12sp"
                    android:layout_marginLeft="5dp"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btnPrestataireMessages"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="💬 Messages"
                    android:backgroundTint="@color/pawly_teal_dark"
                    android:textColor="@color/pawly_white"
                    android:textSize="12sp"
                    android:layout_marginRight="5dp"/>

                <Button
                    android:id="@+id/btnPrestataireJournal"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="📓 Journal"
                    android:backgroundTint="@color/pawly_orange"
                    android:textColor="@color/pawly_white"
                    android:textSize="12sp"
                    android:layout_marginLeft="5dp"/>

            </LinearLayout>

            <!-- Demandes -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📥 Demandes en attente"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/pawly_dark"
                android:layout_marginBottom="10dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDemandes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnPrestataireLogout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="🚪 Se déconnecter"
                android:backgroundTint="@color/pawly_red"
                android:textColor="@color/pawly_white"
                android:textStyle="bold"/>

        </LinearLayout>
    </LinearLayout>
</ScrollView>