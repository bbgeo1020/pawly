<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/pawly_white"
    android:padding="14dp"
    android:layout_marginBottom="6dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="6dp">

        <TextView
            android:id="@+id/tvSignalTitre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="⚠️ Titre"
            android:textStyle="bold"
            android:textColor="@color/pawly_dark"
            android:textSize="15sp"/>

        <TextView
            android:id="@+id/tvSignalStatut"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⏳ En attente"
            android:textSize="12sp"
            android:textColor="@color/pawly_orange"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvSignalDetail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Détail du signalement"
        android:textColor="@color/pawly_grey"
        android:textSize="13sp"
        android:layout_marginBottom="10dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTraiterSignal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="✅ Traiter"
            android:backgroundTint="@color/pawly_teal"
            android:textColor="@color/pawly_white"
            android:textSize="12sp"
            android:layout_marginRight="6dp"/>

        <Button
            android:id="@+id/btnIgnorerSignal"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:text="❌ Ignorer"
            android:backgroundTint="@color/pawly_grey"
            android:textColor="@color/pawly_white"
            android:textSize="12sp"/>

    </LinearLayout>

</LinearLayout>