<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/pawly_background">

    <!-- Header IA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pawly_teal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖"
            android:textSize="28sp"
            android:layout_marginRight="12dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Assistant PAWLY IA"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/pawly_white"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Conseils personnalisés pour votre animal"
                android:textSize="12sp"
                android:textColor="#E0F7F7"/>

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="● En ligne"
            android:textSize="11sp"
            android:textColor="#A5F3C4"/>

    </LinearLayout>

    <!-- Messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvChat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"/>

    <!-- Suggestions -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:background="@color/pawly_white"
        android:paddingTop="6dp"
        android:paddingBottom="6dp">

        <LinearLayout
            android:id="@+id/chipGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"/>

    </HorizontalScrollView>

    <!-- Saisie -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/pawly_white"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/etChatInput"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:hint="Posez votre question..."
            android:background="#F0F0F0"
            android:padding="12dp"
            android:textColor="@color/pawly_dark"
            android:textColorHint="#999999"
            android:layout_marginRight="8dp"/>

        <Button
            android:id="@+id/btnChatSend"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:text="▶"
            android:textSize="18sp"
            android:backgroundTint="@color/pawly_teal"
            android:textColor="@color/pawly_white"
            android:padding="0dp"/>

    </LinearLayout>
</LinearLayout>