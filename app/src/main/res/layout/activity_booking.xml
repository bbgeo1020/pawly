<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Détails de la réservation 📅"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginBottom="20dp"/>

        <!-- Carte offre -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvBookingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titre"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"/>

            <TextView
                android:id="@+id/tvBookingDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textSize="15sp"
                android:textColor="#102A43"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/tvBookingPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00€ / jour"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#D97706"
                android:layout_gravity="end"
                android:layout_marginTop="12dp"/>

        </LinearLayout>

        <!-- Dates -->
        <Button
            android:id="@+id/btnSelectDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅 Choisir la date de début"
            android:backgroundTint="#102A43"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnSelectEndDate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📅 Choisir la date de fin"
            android:backgroundTint="#102A43"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp"/>

        <!-- Récapitulatif -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E8F5E9"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📋 Récapitulatif"
                android:textStyle="bold"
                android:textColor="#1B5E20"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvSummary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sélectionnez les dates pour voir le total."
                android:textColor="#333333"
                android:textSize="14sp"/>

        </LinearLayout>

        <!-- Paiement -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳 Informations de paiement"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#102A43"
            android:layout_marginBottom="12dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Numéro de carte"
                android:textStyle="bold"
                android:textColor="#333333"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etCardNumber"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="1234 5678 9012 3456"
                android:inputType="number"
                android:maxLength="16"
                android:paddingLeft="10dp"
                android:layout_marginBottom="16dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginRight="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expiration"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etExpiry"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="MMAA"
                        android:inputType="number"
                        android:maxLength="4"
                        android:paddingLeft="10dp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CVV"
                        android:textStyle="bold"
                        android:textColor="#333333"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etCvv"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:hint="123"
                        android:inputType="numberPassword"
                        android:maxLength="3"
                        android:paddingLeft="10dp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <Button
            android:id="@+id/btnConfirmPayment"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="💳 Confirmer et Payer"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="16sp"/>

    </LinearLayout>
</ScrollView>