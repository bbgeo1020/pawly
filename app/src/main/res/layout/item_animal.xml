<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/pawly_white"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_margin="4dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAnimalNom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🐕 Rex"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/tvAnimalInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chien — 3 ans"
            android:textSize="13sp"
            android:textColor="@color/pawly_grey"/>

        <TextView
            android:id="@+id/tvAnimalDoc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📄 Pas de document"
            android:textSize="12sp"
            android:textColor="@color/pawly_grey"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnDeleteAnimal"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:text="🗑️"
        android:textSize="16sp"
        android:backgroundTint="@color/pawly_red"
        android:textColor="@color/pawly_white"/>

</LinearLayout>