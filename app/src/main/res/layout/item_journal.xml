<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/pawly_white"
    android:padding="14dp"
    android:gravity="center_vertical"
    android:layout_margin="4dp">

    <TextView
        android:id="@+id/tvEntryEmoji"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:text="🍽️"
        android:textSize="26sp"
        android:gravity="center"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="10dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvEntryTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Titre"
                android:textStyle="bold"
                android:textColor="@color/pawly_dark"
                android:textSize="15sp"/>

            <TextView
                android:id="@+id/tvEntryHeure"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08:30"
                android:textSize="11sp"
                android:textColor="@color/pawly_grey"/>

        </LinearLayout>

        <TextView
            android:id="@+id/tvEntryDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Description"
            android:textColor="@color/pawly_grey"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/tvEntrySuggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Suggestion"
            android:textColor="@color/pawly_primary"
            android:textSize="12sp"
            android:textStyle="italic"
            android:layout_marginTop="2dp"
            android:visibility="gone"/>

    </LinearLayout>

    <Button
        android:id="@+id/btnDeleteEntry"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:text="🗑"
        android:textSize="14sp"
        android:backgroundTint="@color/pawly_red"
        android:textColor="@color/pawly_white"
        android:padding="0dp"
        android:layout_marginLeft="8dp"/>

</LinearLayout>