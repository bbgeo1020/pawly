<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/pawly_white"
    android:padding="16dp"
    android:layout_marginBottom="8dp">

    <TextView
        android:id="@+id/tvDemandeAnimal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🐕 Animal"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/pawly_dark"
        android:layout_marginBottom="6dp"/>

    <TextView
        android:id="@+id/tvDemandeProprietaire"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="👤 Propriétaire"
        android:textSize="14sp"
        android:textColor="@color/pawly_grey"
        android:layout_marginBottom="4dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:id="@+id/tvDemandeDates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📅 Dates"
            android:textSize="14sp"
            android:textColor="@color/pawly_dark"/>

        <TextView
            android:id="@+id/tvDemandePrix"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰 Prix"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/pawly_orange"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnAccepter"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="✅ Accepter"
            android:backgroundTint="@color/pawly_green_ok"
            android:textColor="@color/pawly_white"
            android:textSize="13sp"
            android:layout_marginRight="8dp"/>

        <Button
            android:id="@+id/btnRefuser"
            android:layout_width="0dp"
            android:layout_height="44dp"
            android:layout_weight="1"
            android:text="❌ Refuser"
            android:backgroundTint="@color/pawly_red"
            android:textColor="@color/pawly_white"
            android:textSize="13sp"/>

    </LinearLayout>
</LinearLayout>